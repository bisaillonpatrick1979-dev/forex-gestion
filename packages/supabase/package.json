{
  "name": "@forex/supabase",
  "version": "0.1.0",
  "private": true,
  "description": "Client Supabase + pgvector pour persistance et RAG",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "db:migrate": "node dist/migrations/run.js"
  },
  "dependencies": {
    "@forex/logger": "workspace:*",
    "@forex/rag": "workspace:*",
    "@supabase/supabase-js": "^2.47.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
