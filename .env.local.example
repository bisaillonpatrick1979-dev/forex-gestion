# =============================================================
# Variables d'environnement - Copier vers .env.local
# NE JAMAIS committer .env.local dans Git
# =============================================================

# --- Fournisseur IA actif (openai | anthropic | gemini | ollama) ---
AI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Google Gemini ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (local, après réception du PC) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# --- OANDA ---
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
# OANDA_ENV=live

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug
